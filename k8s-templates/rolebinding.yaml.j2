apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ app_name }}-reader-binding
  namespace: {{ namespace }}
subjects:
  - kind: ServiceAccount
    name: {{ service_account_name }}
    namespace: {{ namespace }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: {{ app_name }}-reader
